generator-speller-gt-norm.%: .generated/generator-speller-gt-norm.tmp.% \
		$(top_builddir)/src/fst/filters/remove-combining-circumflex-accent-below.% \
		$(top_builddir)/src/fst/filters/remove-combining-caron-below.%             \
		$(top_builddir)/src/fst/filters/remove-modifier-letter-grave-accent.%
	$(AM_V_HXFST)$(PRINTF) "read regex                                                     \
			@\"$<\"                                                                        \
		.o. @\"$(top_builddir)/src/fst/filters/remove-combining-caron-below.$*\"             \
		.o. @\"$(top_builddir)/src/fst/filters/remove-modifier-letter-grave-accent.$*\"      \
		.o. @\"$(top_builddir)/src/fst/filters/remove-combining-circumflex-accent-below.$*\" \
		;\n\
		save stack $@\n\
		quit\n" | $(XFST_TOOL) -p $(VERBOSITY)

analyser-speller-gt-norm.%: .generated/generator-speller-gt-norm.tmp.% \
		$(top_builddir)/src/fst/filters/remove-combining-circumflex-accent-below.% \
		$(top_builddir)/src/fst/filters/remove-combining-caron-below.%             \
		$(top_builddir)/src/fst/filters/remove-modifier-letter-grave-accent.%
	$(AM_V_HXFST)$(PRINTF) "read regex                                                     \
			@\"$<\"                                                                        \
		.o. @\"$(top_builddir)/src/fst/filters/remove-combining-caron-below.$*\"             \
		.o. @\"$(top_builddir)/src/fst/filters/remove-modifier-letter-grave-accent.$*\"      \
		.o. @\"$(top_builddir)/src/fst/filters/remove-combining-circumflex-accent-below.$*\" \
		;\n\
		invert\n\
		save stack $@\n\
		quit\n" | $(XFST_TOOL) -p $(VERBOSITY)

